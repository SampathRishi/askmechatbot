# secrets
.env

# python
.venv/
__pycache__/
*.pyc

# crawled / generated data (large; regenerate with pipeline.py) — the whole
# data/ dir is generated (crawl output, vector index, brand, logs, screenshots)
data/

# demo-site/ (index.html, chatbot-widget.js, and assets/) is committed so the
# deployed server can serve the offline homepage replica — the Render build only
# runs `pip install`, it does not regenerate assets. Rebuild locally with
# build_demo.py when the source homepage changes, then commit the result.

# node / frontend build
frontend/node_modules/
# NOTE: frontend/dist/ is intentionally COMMITTED so the deployed backend can
# serve the built React UI without a Node build step on the host. Rebuild it
# with `cd frontend && npm run build` and commit the result when the UI changes.

# os
Thumbs.db
.DS_Store

# Claude Code local session files (machine-specific / ephemeral)
.claude/
