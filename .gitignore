# secrets
.env

# python
.venv/
__pycache__/
*.pyc

# crawled / generated data (large; regenerate with pipeline.py) — the whole
# data/ dir is generated (crawl output, vector index, brand, logs, screenshots)
data/

# generated demo site assets (rebuild with build_demo.py); the hand-written
# demo-site/chatbot-widget.js and generated index.html are kept
demo-site/assets/

# node / frontend build
frontend/node_modules/
# NOTE: frontend/dist/ is intentionally COMMITTED so the deployed backend can
# serve the built React UI without a Node build step on the host. Rebuild it
# with `cd frontend && npm run build` and commit the result when the UI changes.

